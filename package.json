{
  "name": "bale-checker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "db:apply:local": "wrangler d1 execute bale_checker_db --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute bale_checker_db --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute bale_checker_db --local --file=./migrations/0002_add_group_metadata.sql",
    "db:migrate:remote": "wrangler d1 execute bale_checker_db --remote --file=./migrations/0002_add_group_metadata.sql",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
