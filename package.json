{
  "name": "bale-checker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public --d1 DB=bale_checker_db",
    "db:apply:local": "wrangler d1 execute bale_checker_db --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute bale_checker_db --remote --file=./schema.sql",
    "deploy": "wrangler pages deploy public"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
